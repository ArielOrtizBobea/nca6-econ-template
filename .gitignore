# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs — build artifacts, not tracked
paper/main.pdf
paper/talks/*.pdf
# (uncomment below to track all PDFs if you want to commit the compiled chapter)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
.claude/projects/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/
paper/quarto/*_files/
paper/quarto/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
docs/

# Anchor cache — fetched anchor content (don't bloat repo with PDFs)
master_supporting_docs/anchors/cache/*
!master_supporting_docs/anchors/cache/.gitkeep
